#!/usr/bin/env sh
set -eu

if [ "${1:-}" = "" ]; then
  echo "usage: skill-security-review scan <target> [options]" >&2
  exit 64
fi

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
SKILL_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
RUNTIME="$SKILL_ROOT/assets/skill-security-review.pyz"

PYTHON_BIN="${PYTHON:-}"
if [ -z "$PYTHON_BIN" ]; then
  if command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN="python3"
  elif command -v python >/dev/null 2>&1; then
    PYTHON_BIN="python"
  fi
fi

if [ -z "$PYTHON_BIN" ]; then
  echo "python3 or python is required to run skill-security-review." >&2
  exit 127
fi

if [ ! -f "$RUNTIME" ]; then
  echo "Bundled runtime not found: $RUNTIME" >&2
  echo "Reinstall this skill or download a complete release containing assets/skill-security-review.pyz." >&2
  exit 127
fi

exec "$PYTHON_BIN" "$RUNTIME" "$@"
